rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /products/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /reviews/{id} {
      allow read: if resource.data.status == "approved" || request.auth != null;
      allow create: if request.resource.data.status == "pending";
      allow update, delete: if request.auth != null;
    }
    match /orders/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    match /laminates/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /edges/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /settings/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /customers/{id} { allow read, write: if request.auth != null; }
    match /inventory/{id} { allow read, write: if request.auth != null; }
    match /production/{id} { allow read, write: if request.auth != null; }
    match /finance/{id} { allow read, write: if request.auth != null; }
    match /debts/{id} { allow read, write: if request.auth != null; }
    match /workers/{id} { allow read, write: if request.auth != null; }
    match /suppliers/{id} { allow read, write: if request.auth != null; }
    match /purchases/{id} { allow read, write: if request.auth != null; }
    match /laminateSales/{id} { allow read, write: if request.auth != null; }
    match /edgeSales/{id} { allow read, write: if request.auth != null; }
    match /{document=**} { allow read, write: if false; }
  }
}
